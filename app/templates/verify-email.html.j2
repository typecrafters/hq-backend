<body
    style="margin: 0; padding: 0; font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;">
    <table align="center" style="width: 100%; background-color: #ECE7DE; padding: 16px;">
        <tbody>
            <tr>
                <td style="padding: 32px; text-align: center; vertical-align: middle;">
                    <table align="center"
                        style="width: 100%; max-width: 480px; border-radius: 8px; overflow: hidden; border-collapse: separate; border-spacing: 0; box-shadow: 0 4px 6px -1px #9A968B;">
                        <thead>
                            <tr style="background-color: #0B1118; color: white; border: 4px solid --color-cyan-500;">
                                <th colspan="5"
                                    style="background-color: #0B1118; padding: 20px 0 20px 20px; text-align: left; border-bottom: 4px solid #3E97A1;">
                                    <p style="font-family: monospace; font-size: 18px;">
                                        <span style="color: #EC5A2A;">&lt;</span><span style="color: #F4F0E7;">T</span><span
                                            style="color: #EC5A2A;">&gt;</span><span style="color: #F4F0E7;">ypecrafters</span><span
                                            style="color: #EC5A2A;">;</span>
                                    </p>
                                </th>
                                <th colspan="1"
                                    style="background-color: #0B1118; padding: 20px 020px 20px 0; text-align: right; border-bottom: 4px solid #3E97A1;">
                                    <span
                                        style="border-radius: 9999px; border: 1px solid #EC5A2A; color: #EC5A2A; background-color: #482924; padding: 4px 12px; font-size: 12px; font-weight: 400; font-family: monospace;">VERIFY</span>
                                </th>
                            </tr>
                        </thead>
                        <tbody style="background-color: white;">
                            <tr>
                                <td 
                                    colspan="6"
                                    style=" padding: 24px 24px 0 24px; width: 100%; color: #3B4957; font-family: monospace; font-size: 14px; text-align: left;"
                                >ACTION REQUIRED</td>
                            </tr>
                            <tr>
                                <td 
                                    colspan="6"
                                    style="padding: 16px 24px; font-size: 24px; font-weight: 600; color: black; text-align: left;"
                                >Confirm your email address</td>
                            </tr>
                            <tr>
                                <td colspan="6" style="padding: 16px 24px;">
                                    <p style="color: #0B1118; text-align: left;">Hey <b>{{ first_name | capitalize }}</b>,</p>
                                    <p style="color: #0B1118; text-align: left;">
                                        You've been added to the TypeCrafters studio
                                        admin panel. Before you can sign in, we need
                                        to verify this email address belongs to you.
                                    </p>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="6" style="padding: 16px 24px; text-align: left;">
                                    <a href="{{ url }}"
                                        style="display: inline-block; text-decoration: none; font-weight: 500; padding: 8px 16px; border-radius: 6px; color: white; background-color: #EC5A2A; cursor: pointer;">
                                        Verify email address
                                    </a>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="6" style="padding: 16px 24px">
                                    <p
                                        style="padding: 16px; background-color: #F4F0E7; border-radius: 6px; border: 1px solid #C5C0B6;">
                                        <span
                                            style="display: block; font-family: monospace; color: #3B4957; padding-bottom: 8px; text-align: left;">Button
                                            not working?</span>
                                        <span style="display: block; text-align: left;">Copy and paste this link into your broswer:</span>
                                        <a href="{{ url }}"
                                            style="display: block; color: #3E97A1; text-decoration: underline; text-align: left;">{{ url }}</a>
                                    </p>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="6" style="padding: 16px 24px;">
                                    <p
                                        style="padding: 16px; text-align: left; background-color: #FFEEEB; color: #B64840; border-radius: 6px; border: 1px solid #B64840;">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                                            <path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/>
                                        </svg>
                                        <span>
                                            This link expires in <b>{{ expires_in }}</b>.
                                            If you didn't expect this email, you
                                            can safely ignore it — your account
                                            won't be activated.
                                        </span>
                                    </p>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="6" style="padding: 8px 24px;">
                                    <hr style="border-top: 1px solid #C5C0B6;">
                                </td>
                            </tr>
                            <tr>
                                <td colspan="6" style="padding: 16px 24px;">
                                    <p style="color: #3B4957; text-align: left;">
                                        Questions? Reply to this email or reach
                                        the team at 
                                        <a href="mailto:typecrafters0@gmail.com" style="color: #3E97A1; text-decoration: underline;">
                                            typecrafters0@gmail.com
                                        </a>
                                    </p>
                                </td>
                            </tr>
                        </tbody>
                        <tfoot style="background-color: #F4F0E7;">
                            <tr>
                                <td colspan="5" style="padding: 16px 0 8px 24px;">
                                    <p style="font-size: 14px; margin: 0; color: #79746B; text-align: left;">TypeCrafters, LLC&nbsp;&middot;&nbsp;Studio Admin</p>
                                </td>
                                <td colspan="1" style="padding: 16px 24px 8px 0;">
                                    <p style="font-size: 14px; margin: 0; font-family: monospace; text-align: right;"><span style="color: #EC5A2A;">&lt;</span>T<span style="color: #EC5A2A;">&gt;</span></p>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="6" style="padding: 8px 24px 16px 24px; font-size: 14px; color: #9A968B;">
                                    You received this because an admin invited you to typecrafters.com
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </td>
            </tr>
        </tbody>
    </table>
</body>